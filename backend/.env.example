
INFLUXDB_URL=
BACKEND_PORT=
MQTT_BROKER_URL=

# InfluxDB Docker first-run initialization (used by docker-compose influxdb service)
DOCKER_INFLUXDB_INIT_USERNAME=<username>
DOCKER_INFLUXDB_INIT_PASSWORD=<password>
DOCKER_INFLUXDB_INIT_ORG=<org_name>
DOCKER_INFLUXDB_INIT_BUCKET=<bucket_name>
DOCKER_INFLUXDB_INIT_RETENTION=<retention_period> # e.g., 720h for 30 days
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=<hardcoded_admin_token>

# Tokens (set manually after InfluxDB setup)
INFLUXDB_BACKEND_TOKEN=<backend_token>
INFLUXDB_FRONTEND_TOKEN=<frontend_token>